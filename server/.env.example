# ── MongoDB ──────────────────────────────────────────────────
# Get this from https://cloud.mongodb.com → Create Cluster → Connect
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# ── Email (Gmail) ─────────────────────────────────────────────
# Your Gmail address
EMAIL_USER=shandosh6381aathi@gmail.com

# Gmail App Password (NOT your Gmail password!)
# Steps to get it:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Search "App Passwords" → Create one for "Mail"
#   4. Copy the 16-character code and paste it below (spaces are optional)
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Where to send notification emails (defaults to EMAIL_USER if not set)
EMAIL_TO=shandosh6381aathi@gmail.com

# ── Server ────────────────────────────────────────────────────
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
